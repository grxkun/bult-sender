{
  "name": "bult-sender",
  "version": "1.0.0",
  "description": "A tool to send tokens to multiple addresses (bulk transfer) on EVM chains",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "bulk",
    "token",
    "transfer",
    "evm",
    "ethereum",
    "web3"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^14.0.1",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "ethers": "^6.8.0",
    "inquirer": "^9.2.12"
  },
  "devDependencies": {
    "@jest/types": "^30.2.0",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
}
