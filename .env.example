# Environment Configuration
# Copy this file to .env and fill in your values

# Ethereum RPC URL (use Infura, Alchemy, or your own node)
RPC_URL=https://eth-mainnet.alchemyapi.io/v2/YOUR_API_KEY

# Private key of the wallet that will send tokens (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Contract address of the token you want to send (ERC-20)
TOKEN_CONTRACT_ADDRESS=0x...

# Bulk sender contract address (will be set after deployment)
BULK_SENDER_CONTRACT_ADDRESS=0x...

# Gas settings (optional)
GAS_PRICE=20000000000
GAS_LIMIT=500000